{
  "expo": {
    "name": "Jolley Volley",
    "slug": "jolley-volley",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0214"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.matthewelijahlogan.jolleyvolley"
    },
    "android": {
      "package": "com.matthewelijahlogan.jolleyvolley",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0b0214"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
